# EduMind Environment Configuration
# Copy this to .env and fill in values

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=edumind
POSTGRES_PASSWORD=edumind_secret
POSTGRES_DB=edumind

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Models (optional - stubs used if not set)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=gpt-3.5-turbo
LLM_API_KEY=
WHISPER_MODEL=small

# Feature Flags
ENABLE_VQA=false
ENABLE_TABLE_QA=false
ENABLE_ORAL=false

# Debug
DEBUG=false
